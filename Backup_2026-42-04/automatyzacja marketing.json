        "jsCode": "// ===== BUDŻET =====\nlet budget = $json.custom_fields?.[0]?.value;\n\nif (budget) {\n  $json.custom_fields[0].value = budget.toString().replace(/\\D/g, \"\");\n}\n\n// ===== TELEFON =====\nlet phone = $json.custom_fields?.[2]?.value;\n\nif (phone) {\n  phone = phone.toString().replace(/\\D/g, \"\");\n\n  if (phone.length === 9) {\n    phone = \"+48\" + phone;\n  }\n\n  if (!phone.startsWith(\"+\")) {\n    phone = \"+\" + phone;\n  }\n\n  $json.custom_fields[2].value = phone;\n}\n\nconst timestamp = Number($json.date_created);\n\nif (!isNaN(timestamp)) {\n  const date = new Date(timestamp);\n\n  const formatted =\n    date.getFullYear() + \"-\" +\n    String(date.getMonth() + 1).padStart(2, \"0\") + \"-\" +\n    String(date.getDate()).padStart(2, \"0\");\n\n  // nadpisujemy oryginalne pole\n  $json.date_created = formatted;\n}\n\n\n// ✅ ZWRACAMY ORYGINALNY OBIEKT\nreturn [\n  {\n    json: { ...$json }\n  }\n];"
