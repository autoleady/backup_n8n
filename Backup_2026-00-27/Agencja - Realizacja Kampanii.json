      "id": "24427a8a-43fd-44c6-a5e3-b69d86e670be",
      "name": "📊 Pobierz aktywne kampanie",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        -448,
        704
      ]
    },
    {
      "parameters": {
        "jsCode": "const campaigns = $input.all();\nconst alerts = [];\n\nfor (const camp of campaigns) {\n  const c = camp.json;\n  \n  const budzet = parseFloat(c['Budżet dzienny'] || 0);\n  const wydane = parseFloat(c['Wydane dzisiaj'] || 0);\n  const cpcTarget = parseFloat(c['CPC target'] || 0);\n  const cpcAktualny = parseFloat(c['CPC aktualny'] || 0);\n  const ctrTarget = parseFloat(c['CTR target'] || 0);\n  const ctrAktualny = parseFloat(c['CTR aktualny'] || 0);\n  const konwersje = parseInt(c['Konwersje dzisiaj'] || 0);\n  \n  const procentBudzetu = budzet > 0 ? (wydane / budzet) * 100 : 0;\n  const wzrostCPC = cpcTarget > 0 ? ((cpcAktualny - cpcTarget) / cpcTarget) * 100 : 0;\n  const spadekCTR = ctrTarget > 0 ? ((ctrTarget - ctrAktualny) / ctrTarget) * 100 : 0;\n  \n  const alerty = [];\n  let poziomAlertu = 'INFO';\n  \n  if (procentBudzetu >= 90) {\n    alerty.push(`🔴 Budżet wykorzystany w ${procentBudzetu.toFixed(0)}%`);\n    poziomAlertu = 'KRYTYCZNY';\n  } else if (procentBudzetu >= 75) {\n    alerty.push(`🟡 Budżet wykorzystany w ${procentBudzetu.toFixed(0)}%`);\n    if (poziomAlertu !== 'KRYTYCZNY') poziomAlertu = 'OSTRZEZENIE';\n  }\n  \n  if (wzrostCPC >= 30) {\n    alerty.push(`🔴 CPC wzrósł o ${wzrostCPC.toFixed(0)}% (target: ${cpcTarget} zł, aktualny: ${cpcAktualny} zł)`);\n    poziomAlertu = 'KRYTYCZNY';\n  } else if (wzrostCPC >= 15) {\n    alerty.push(`🟡 CPC wzrósł o ${wzrostCPC.toFixed(0)}%`);\n    if (poziomAlertu !== 'KRYTYCZNY') poziomAlertu = 'OSTRZEZENIE';\n  }\n  \n  if (spadekCTR >= 30) {\n    alerty.push(`🔴 CTR spadł o ${spadekCTR.toFixed(0)}% (target: ${ctrTarget}%, aktualny: ${ctrAktualny}%)`);\n    poziomAlertu = 'KRYTYCZNY';\n  }\n  \n  if (konwersje === 0 && wydane > 50) {\n    alerty.push(`🔴 Brak konwersji przy wydanych ${wydane} zł`);\n    poziomAlertu = 'KRYTYCZNY';\n  }\n  \n  if (alerty.length > 0) {\n    alerts.push({\n      json: {\n        kampaniaNazwa: c['Nazwa kampanii'] || 'Brak nazwy',\n        klientNazwa: c['Klient'] || 'Brak klienta',\n        specjalistaEmail: c['Email specjalisty'] || 'specjalista@agencja.pl',\n        platforma: c['Platforma'] || 'Google Ads',\n        budzet,\n        wydane,\n        procentBudzetu: procentBudzetu.toFixed(0),\n        cpcTarget,\n        cpcAktualny,\n        ctrTarget,\n        ctrAktualny,\n        konwersje,\n        alerty,\n        poziomAlertu,\n        alertyHTML: alerty.map(a => `<li style='padding:6px 0;'>${a}</li>`).join('')\n      }\n    });\n  }\n}\n\nif (alerts.length === 0) {\n  return [{ json: { brakAlertow: true, message: 'Wszystkie kampanie w normie' } }];\n}\n\nreturn alerts;"
      },
