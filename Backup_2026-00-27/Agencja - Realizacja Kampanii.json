    {
      "parameters": {
        "jsCode": "const tasks = $input.all();\nconst result = [];\n\nfor (const task of tasks) {\n  const t = task.json;\n  \n  const klientEmail = t.custom_fields?.find(f => f.name === 'Email Klienta')?.value || 'brak@email.com';\n  const klientNazwa = t.custom_fields?.find(f => f.name === 'Nazwa Klienta')?.value || 'Klient';\n  const tresc = t.custom_fields?.find(f => f.name === 'Treść Posta')?.value || t.description || '';\n  const platforma = t.custom_fields?.find(f => f.name === 'Platforma')?.value || 'Social Media';\n  const dataPublikacji = t.custom_fields?.find(f => f.name === 'Data Publikacji')?.value || '';\n  const emailWyslany = t.custom_fields?.find(f => f.name === 'Email Akceptacji Wysłany')?.value || 'NIE';\n  \n  if (emailWyslany === 'NIE' || emailWyslany === '' || emailWyslany === null) {\n    result.push({\n      json: {\n        taskId: t.id,\n        taskName: t.name,\n        klientEmail,\n        klientNazwa,\n        tresc,\n        platforma,\n        dataPublikacji,\n        taskUrl: t.url,\n        akceptacjaLink: `https://TWOJA_DOMENA.com/webhook/akceptacja?taskId=${t.id}&akcja=akceptuj`,\n        odrzucenieLink: `https://TWOJA_DOMENA.com/webhook/akceptacja?taskId=${t.id}&akcja=odrzuc`\n      }\n    });\n  }\n}\n\nreturn result;"
      },
