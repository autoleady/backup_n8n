    {
      "parameters": {
        "jsCode": "const tasks = items[0].json.tasks || [];\nconst now = new Date();\nconst monthNames = ['Styczeń','Luty','Marzec','Kwiecień','Maj','Czerwiec','Lipiec','Sierpień','Wrzesień','Październik','Listopad','Grudzień'];\nconst monthLabel = `${monthNames[now.getMonth()]} ${now.getFullYear()}`;\n\nconst getFieldValue = (task, name) => {\n    const field = task.custom_fields?.find(f => f.name?.toLowerCase() === name.toLowerCase());\n    if (!field) return 0;\n    if (field.value !== undefined) {\n        if (typeof field.value === 'number') return field.value;\n        if (typeof field.value === 'string') return parseFloat(field.value) || 0;\n        if (typeof field.value === 'object' && field.value.text) return parseFloat(field.value.text) || 0;\n    }\n    if (field.text) return parseFloat(field.text) || 0;\n    return 0;\n};\n\nconst summary = {};\n\ntasks.forEach(task => {\n    const status = task.status?.status || 'Brak statusu';\n    const cena = getFieldValue(task, 'Cena');\n    if (!summary[status]) summary[status] = { count: 0, totalRevenue: 0 };\n    summary[status].count += 1;\n    summary[status].totalRevenue += cena;\n});\n\nconst rows = Object.keys(summary).map(status => ({\n    json: {\n        Miesiac: monthLabel,\n        Status: status,\n        Liczba_klientow: summary[status].count,\n        Suma_przychodow: summary[status].totalRevenue\n    }\n}));\n\nreturn rows.length > 0 ? rows : [{ json: { Miesiac: monthLabel, Status: '', Liczba_klientow: 0, Suma_przychodow: 0 } }];"
      },
