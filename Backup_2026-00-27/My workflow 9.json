    {
      "parameters": {
        "jsCode": "return items.length > 0\n  ? items.map(item => {\n      const task = item.json;\n\n      // Funkcja uniwersalna do pobierania wartości pola\n      const getFieldValue = (fieldName) => {\n        const field = task.custom_fields?.find(f => f.name?.toLowerCase() === fieldName.toLowerCase());\n        if (!field) return '';\n\n        // możliwe typy w ClickUp\n        if (field.value !== undefined) {\n          if (typeof field.value === 'string' || typeof field.value === 'number') return field.value;\n          if (typeof field.value === 'object') {\n            if (field.value.email) return field.value.email;\n            if (field.value.text) return field.value.text;\n          }\n        }\n        if (field.text) return field.text; // text fields\n        if (field.email) return field.email;\n        return '';\n      };\n\n      // Przetwarzanie pól\n      const imie = getFieldValue('Imie') || ''; // **bez replace(/\\D/g,'')**\n      const firma = getFieldValue('Nazwa firmy') || ''; // **bez replace**\n      const tel = (getFieldValue('Telefon') || '').replace(/\\D/g, ''); // tylko tel -> cyfry\n      const email = getFieldValue('Email') || '';\n      const cena = getFieldValue('Cena') || '';\n      const opis = getFieldValue('Opis') || '';\n      const status = task.status?.status || '';\n      const abonament = getFieldValue('Abonament') ? 'TAK' : 'NIE';\n\n      return { json: { imie, firma, tel, email, cena, opis, status, abonament } };\n    })\n  : [{ json: {} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
