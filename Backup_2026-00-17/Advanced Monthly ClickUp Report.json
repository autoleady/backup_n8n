    {
      "parameters": {
        "functionCode": "const lastMonthStart = new Date();\nlastMonthStart.setMonth(lastMonthStart.getMonth() - 1);\nlastMonthStart.setDate(1);\n\nconst lastMonthEnd = new Date();\nlastMonthEnd.setDate(0);\n\nreturn items.filter(item => {\n  const date = new Date(item.json.date_created);\n  return date >= lastMonthStart && date <= lastMonthEnd;\n});"
      },
      "id": "3702b3fa-d8d1-4536-b2e5-a6ab74705ea6",
      "name": "Filter Last Month",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        400,
        0
      ]
    },
    {
      "parameters": {
        "functionCode": "const result = {};\n\nitems.forEach(item => {\n  const status = item.json.status?.status || 'unknown';\n\n  if (!result[status]) {\n    result[status] = {\n      status,\n      count: 0\n    };\n  }\n\n  result[status].count += 1;\n});\n\nreturn Object.values(result).map(r => ({ json: r }));"
      },
      "id": "6e3a17ee-4521-4ca7-8bbf-465f60aeed36",
      "name": "Aggregate by Status",
