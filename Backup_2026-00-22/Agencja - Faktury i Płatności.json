    {
      "parameters": {
        "jsCode": "// Połącz dane faktury z treścią AI\nconst invoiceData = $('⚙️ Przygotuj dane faktur').item.json;\nconst aiResponse = $input.first().json;\n\n// Wyciągnij treść z odpowiedzi AI\nconst aiContent = aiResponse.choices?.[0]?.message?.content || \n  `W załączniku przesyłamy fakturę za ${invoiceData.miesiac}. Termin płatności: ${invoiceData.dataplatnosciPL}.`;\n\nreturn [{\n  json: {\n    ...invoiceData,\n    aiEmailContent: aiContent\n  }\n}];"
      },
