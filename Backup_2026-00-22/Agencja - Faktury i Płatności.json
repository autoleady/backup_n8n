      "id": "afe43cf7-cd1f-49ae-9463-93be0b026673",
      "name": "📊 Pobierz aktywnych klientów",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        -448,
        128
      ]
    },
    {
      "parameters": {
        "jsCode": "// Przygotuj dane każdego klienta do wystawienia faktury\nconst items = $input.all();\nconst results = [];\n\nconst now = new Date();\nconst miesiac = now.toLocaleDateString('pl-PL', { month: 'long', year: 'numeric' });\nconst miesiacNum = String(now.getMonth() + 1).padStart(2, '0');\nconst rok = now.getFullYear();\n\n// Data płatności - 14 dni od dziś\nconst dataplatnosci = new Date();\ndataplatnosci.setDate(dataplatnosci.getDate() + 14);\nconst dataplatnosciPL = dataplatnosci.toLocaleDateString('pl-PL');\nconst dataplatnosciISO = dataplatnosci.toISOString();\n\n// Data wystawienia\nconst dataWystawienia = now.toLocaleDateString('pl-PL');\n\nfor (const item of items) {\n  const klient = item.json;\n  \n  // Generuj numer faktury\n  const numerFaktury = `FV/${rok}/${miesiacNum}/${String(results.length + 1).padStart(3, '0')}`;\n  \n  // Oblicz kwoty\n  const kwotaNetto = parseFloat(klient['Wartość umowy'] || 0);\n  const vat = Math.round(kwotaNetto * 0.23 * 100) / 100;\n  const kwotaBrutto = Math.round((kwotaNetto + vat) * 100) / 100;\n  \n  results.push({\n    json: {\n      // Dane klienta\n      klientId: klient['ID Projektu'] || '',\n      klientNazwa: klient['Nazwa Klienta'] || '',\n      klientEmail: klient['Email'] || '',\n      klientNIP: klient['NIP'] || '',\n      klientAdres: klient['Adres'] || '',\n      pakiet: klient['Pakiet'] || '',\n      clickupTaskId: klient['ClickUp Task ID'] || '',\n      \n      // Dane faktury\n      numerFaktury,\n      dataWystawienia,\n      dataplatnosciPL,\n      dataplatnosciISO,\n      miesiac,\n      miesiacNum,\n      rok: String(rok),\n      \n      // Kwoty\n      kwotaNetto: kwotaNetto.toFixed(2),\n      vat: vat.toFixed(2),\n      kwotaBrutto: kwotaBrutto.toFixed(2),\n      \n      // Status\n      statusFaktury: 'WYSTAWIONA',\n      dataWystawieniaISO: now.toISOString()\n    }\n  });\n}\n\nreturn results;"
      },
