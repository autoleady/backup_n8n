    {
      "parameters": {
        "jsCode": "// ===============================\n// POBRANIE DANYCH Z CLICKUP\n// ===============================\n\nconst data = $json;\nconst fields = data.custom_fields || [];\n\n// Sprawdzenie czy pola przyszły\nif (fields.length === 0) {\n  return [{\n    json: {\n      blad: true,\n      komunikat: \"Brak custom_fields\",\n      task_id: data.id || null\n    }\n  }];\n}\n\n\n// ===============================\n// FUNKCJA — POBIERZ PO NAZWIE\n// ===============================\n\nconst getFieldByName = (name) => {\n  const field = fields.find(f => \n    f.name && f.name.toLowerCase().includes(name.toLowerCase())\n  );\n  \n  if (!field) return '';\n  \n  const value = field.value;\n  \n  if (value === null || value === undefined) return '';\n  \n  // Jeśli to dropdown (array opcji)\n  if (Array.isArray(value)) {\n    if (value.length === 0) return '';\n    return value[0]?.name || value[0]?.label || '';\n  }\n  \n  // Jeśli to obiekt z name\n  if (typeof value === 'object' && value?.name) {\n    return value.name;\n  }\n  \n  // Jeśli to string lub liczba\n  return String(value);\n};\n\n\n// ===============================\n// FUNKCJA — POBIERZ PO INDEKSIE\n// ===============================\n\nconst getFieldByIndex = (fieldIndex) => {\n  const field = fields[fieldIndex];\n  \n  if (!field) return '';\n  \n  const value = field.value;\n  \n  if (!value) return '';\n  \n  // Jeśli to dropdown (array opcji)\n  if (Array.isArray(value)) {\n    if (value.length === 0) return '';\n    return value[0]?.name || value[0]?.label || '';\n  }\n  \n  // Jeśli to obiekt z name\n  if (typeof value === 'object' && value?.name) {\n    return value.name;\n  }\n  \n  // Jeśli to string lub liczba\n  if (value !== null && value !== undefined) {\n    return String(value);\n  }\n  \n  return '';\n};\n\n\n// ===============================\n// FUNKCJA — CHECKBOX TAK/NIE\n// ===============================\n\nconst getCheckboxValue = (fieldIndex) => {\n  const field = fields[fieldIndex];\n  \n  if (!field) return 'Nie';\n  \n  const value = field.value;\n  \n  // Checkbox w ClickUp zwraca true/false\n  if (value === true) return 'Tak';\n  if (value === false) return 'Nie';\n  \n  // Czasem przychodzi jako string\n  if (value === 'true' || value === '1') return 'Tak';\n  if (value === 'false' || value === '0') return 'Nie';\n  \n  return 'Nie';\n};\n\n\n// ===============================\n// FUNKCJA — TELEFON SAME CYFRY\n// ===============================\n\nconst getPhoneDigits = (fieldNameVariants) => {\n  let raw = '';\n  for (const name of fieldNameVariants) {\n    raw = getFieldByName(name);\n    if (raw) break;\n  }\n  if (!raw) return '';\n  return raw.replace(/\\D/g, '');\n};\n\n\n// ===============================\n// ODCZYT PÓL\n// ===============================\n\n// Pola po nazwach (zmień nazwy na swoje warianty)\nconst nazwa_firmy   = getFieldByName('nazwa') || \n                      getFieldByName('firma') || \n                      getFieldByName('company') || \n                      getFieldByName('klient');\n\nconst email         = getFieldByName('email') || \n                      getFieldByName('mail') || \n                      getFieldByName('e-mail');\n\nconst telefon       = getPhoneDigits(['tel', 'telefon', 'phone', 'mobile']);\n\nconst opis          = getFieldByName('opis') || \n                      getFieldByName('description') || \n                      getFieldByName('info');\n\nconst branza        = getFieldByName('branża') || \n                      getFieldByName('branza') || \n                      getFieldByName('industry') || \n                      getFieldByName('sektor');\n\n// Pole [0] — pierwsze pole (zamiast [10])\nconst pole0_wartosc = getFieldByIndex(0);\nconst pole0_nazwa   = fields[0]?.name || 'Pole_0';\n\n// Pole [2] — checkbox Tak/Nie (zamiast [5])\nconst pole2_tak_nie = getCheckboxValue(2);\nconst pole2_nazwa   = fields[2]?.name || 'Pole_2';\n\n// Pole [3] — checkbox Tak/Nie (zamiast [6])\nconst pole3_tak_nie = getCheckboxValue(3);\nconst pole3_nazwa   = fields[3]?.name || 'Pole_3';\n\n\n// ===============================\n// ZWRACAMY DANE DO GOOGLE SHEETS\n// ===============================\n\nreturn [{\n  json: {\n    // Pola podstawowe\n    nazwa_firmy:    nazwa_firmy || 'Brak nazwy',\n    email:          email || '',\n    telefon:        telefon || '',\n    opis:           opis || '',\n    branza:         branza || '',\n    \n    // Pole [0] — wartość tekstowa\n    [pole0_nazwa]:  pole0_wartosc,\n    pole_0_wartosc: pole0_wartosc,  // duplikat dla pewności\n    \n    // Pole [2] — Tak/Nie\n    [pole2_nazwa]:  pole2_tak_nie,\n    pole_2_taknie:  pole2_tak_nie,  // duplikat dla pewności\n    \n    // Pole [3] — Tak/Nie\n    [pole3_nazwa]:  pole3_tak_nie,\n    pole_3_taknie:  pole3_tak_nie,  // duplikat dla pewności\n    \n    // Metadata\n    data_dodania:   new Date().toLocaleDateString('pl-PL')\n  }\n}];"
      },
