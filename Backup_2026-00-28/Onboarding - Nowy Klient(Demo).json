      "parameters": {
        "jsCode": "const fields = $json.custom_fields || [];\nconst getEmail = () => {\n  const field = fields.find(f => f.name && f.name.toLowerCase().includes('mail'));\n  return field?.value || '';\n};\n\nconst email = getEmail();\n\nif (!email) {\n  // Jeśli brak emaila, przerwij workflow lub ustaw domyślny\n  return [{ json: { skip: true } }];\n}\n\nconst nazwa_firmy = email.split('@')[1] || 'Nieznana firma';\n\nreturn [{\n  json: {\n    email,\n    nazwa_firmy,\n    status: 'nowy_lead'\n  }\n}];"
