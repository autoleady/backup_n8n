      ],
      "webhookId": "84f44de4-1d89-4e5e-930d-c302398029d2"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst data = raw.body || raw;\n\n// Konfiguracja zespołów\nconst TEAMS = {\n  'hostessy': {\n    listId: 'LIST_ID_HOSTESSY',\n    managerEmail: 'manager.hostessy@firma.pl',\n    typProduktu: 'Coca-Cola',\n    godzinaStart: '08:00',\n    godzinaKoniec: '18:00'\n  },\n  'rejestracja': {\n    listId: 'LIST_ID_REJESTRACJA',\n    managerEmail: 'manager.rejestracja@firma.pl',\n    typProduktu: 'Identyfikatory',\n    godzinaStart: '07:30',\n    godzinaKoniec: '17:00'\n  },\n  'logistyka': {\n    listId: 'LIST_ID_LOGISTYKA',\n    managerEmail: 'manager.logistyka@firma.pl',\n    typProduktu: 'Paczki',\n    godzinaStart: '07:00',\n    godzinaKoniec: '19:00'\n  },\n  'ochrona': {\n    listId: 'LIST_ID_OCHRONA',\n    managerEmail: 'manager.ochrona@firma.pl',\n    typProduktu: 'Przepustki',\n    godzinaStart: '06:00',\n    godzinaKoniec: '22:00'\n  },\n  'catering': {\n    listId: 'LIST_ID_CATERING',\n    managerEmail: 'manager.catering@firma.pl',\n    typProduktu: 'Posilki',\n    godzinaStart: '09:00',\n    godzinaKoniec: '20:00'\n  },\n  'vip': {\n    listId: 'LIST_ID_VIP',\n    managerEmail: 'manager.vip@firma.pl',\n    typProduktu: 'VIP Pakiety',\n    godzinaStart: '08:00',\n    godzinaKoniec: '18:00'\n  }\n};\n\nconst zespolKey = (data.zespol || '').toLowerCase().trim();\nconst teamConfig = TEAMS[zespolKey] || null;\n\n// Walidacja\nconst errors = [];\nif (!data.imie_nazwisko) errors.push('Brak imienia i nazwiska');\nif (!data.zespol) errors.push('Brak zespolu');\nif (!data.email) errors.push('Brak emaila');\nif (!teamConfig) errors.push('Nieznany zespol: ' + zespolKey);\n\n// Oblicz spoznienie\nconst now = new Date();\nconst godzina = data.godzina_przyjscia ||\n  now.getHours().toString().padStart(2,'0') + ':' +\n  now.getMinutes().toString().padStart(2,'0');\n\nlet spoznienie = 0;\nlet czyPunktualna = true;\nlet czySpozniona = false;\n\nif (teamConfig) {\n  const [hStart, mStart] = teamConfig.godzinaStart.split(':').map(Number);\n  const [hPrzyjscie, mPrzyjscie] = godzina.split(':').map(Number);\n  spoznienie = (hPrzyjscie * 60 + mPrzyjscie) - (hStart * 60 + mStart);\n  czyPunktualna = spoznienie <= 0;\n  czySpozniona = spoznienie > 15;\n}\n\nconst dataFormatted = now.toLocaleDateString('pl-PL');\n\nreturn [{\n  json: {\n    // Dane pracownika\n    imie_nazwisko: data.imie_nazwisko || '',\n    email: data.email || '',\n    telefon: data.telefon || '',\n    zespol: data.zespol || '',\n    stanPoczatkowy: parseInt(data.stan_poczatkowy) || 0,\n    \n    // Konfiguracja zespołu\n    teamConfig,\n    listId: teamConfig ? teamConfig.listId : null,\n    managerEmail: teamConfig ? teamConfig.managerEmail : null,\n    \n    // Czas\n    godzina,\n    spoznienie,\n    czyPunktualna,\n    czySpozniona,\n    dataFormatted,\n    timestamp: now.toISOString(),\n    \n    // Etap startowy\n    etapObecny: '2 - Zameldowal sie',\n    statusObecnosci: czySpozniona \n      ? 'Obecny - spoźniony' \n      : 'Obecny - punktualny',\n    \n    // Walidacja\n    errors,\n    isValid: errors.length === 0\n  }\n}];"
      },
