        "jsCode": "const walidacja = $('Walidacja i Config').item.json;\nconst taskResponse = $input.first().json;\n\nif (!taskResponse.id) {\n  throw new Error('Nie udalo sie stworzyc taska w ClickUp. Odpowiedz: ' + JSON.stringify(taskResponse));\n}\n\nreturn [{\n  json: {\n    taskId: taskResponse.id,\n    taskUrl: taskResponse.url,\n    taskName: taskResponse.name,\n    ...walidacja\n  }\n}];"
